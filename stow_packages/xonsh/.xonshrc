$SHELL_TYPE = 'prompt_toolkit'
$COLOR_INPUT = True
$XONSH_COLOR_STYLE = 'default'
$XONSH_HISTORY_BACKEND = 'sqlite'  # Faster and better for multiple sessions
$CASE_SENSITIVE_COMPLETIONS = False
$COMPLETIONS_CONFIRM = True        # Press Enter once to select, twice to run
$UPDATE_OS_ENVIRON = True          # Keep OS environment variables in sync

xontrib load fzf-completions

$fzf_history_binding = "c-r"
$fzf_ssh_binding = "c-s"
$fzf_file_binding = "c-t"
$fzf_dir_binding = "c-g"

if 'oh-my-posh' in __xonsh__.commands_cache:
    execx($(oh-my-posh init xonsh --config ~/.omp-main.yml))

if 'zoxide' in __xonsh__.commands_cache:
    execx($(zoxide init --cmd cd xonsh))

aliases['ls'] = ['ls', '--color']
aliases['ll'] = ['lsd', '-l']
aliases['la'] = ['lsd', '-la']
aliases['lt'] = ['lsd', '-la', '--tree']
aliases['ccat'] = ['/bin/cat']

if 'bat' in __xonsh__.commands_cache:
    aliases['cat'] = ['bat', '-pp']
elif 'batcat' in __xonsh__.commands_cache:
    aliases['cat'] = ['batcat', '-pp']
    aliases['bat'] = ['batcat']

aliases['ipy'] = 'ipython'
aliases['nv'] = 'nvim'
aliases['x'] = 'xonsh'

from pathlib import Path

_env_dir = Path.home() / ".env_scripts"
if _env_dir.is_dir():
    for _f in _env_dir.glob("*.xsh"):
        source @(str(_f))
    for _f in _env_dir.glob("*.py"):
        source @(str(_f))

    for _f in _env_dir.glob("*.sh"):
        source-bash @(str(_f))
